---
import oceanBg from "../assets/background.png";
---

<section class="activities">
    <div>
        <h1>AI4Ocean 2026 Workshop</h1>
    </div>
</section>

<style>
    .activities {
        padding: 0 0.4rem;
        padding-top: var(--header-h);
        min-height: 50vh;
        box-sizing: border-box;
        width: 100%;
        color: green;
    }

    .activities h1 {
        max-width: min(100%, 500px);
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0;
    }
    

    @media (min-width: 768px) {
        .activities {
            padding: 0 5rem;
            padding-top: var(--header-h);
        }
    }
</style>
