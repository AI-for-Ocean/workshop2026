---
import oceanBg from "../assets/background.jpg";
---

<section
    class="welcome"
    style={`background-image: linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.45)), url(${oceanBg.src});`}
>
    <div>
        <h1>AI4Ocean</h1>

        <div class="meta-row">
            <p class="meta">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                    ></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                <span>20 - 31 July</span>
            </p>

            <p class="meta">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <span>Seattle, Washington</span>
            </p>
        </div>
    
        <p class="desc">A two-week workshop on current research and development in AI for oceans.</p>
    </div>
</section>

<style>
    .welcome {
        min-height: 65vh;
        background-size: 100% 100%;
        background-position: center;
        display: flex;
        place-items: center;
        color: #fff;
        text-align: center;
        padding: 0 40px;
        padding-top: var(--header-h);
    }

    .desc {
        max-width: 500px;
        font-size: 1.8rem;
    }

    h1 {
        margin: 0 0 20px;
        font-size: 6rem;
        font-weight: 900;
    }

    .meta-row {
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .meta {
        margin: 8px 0;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .meta svg {
        width: 30px;
        height: 30px;
        stroke: currentColor;
        fill: none;
        stroke-width: 2;
        flex-shrink: 0;
    }
</style>
