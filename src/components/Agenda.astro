<section class="agenda" id="agenda">
    <h2>Agenda</h2>

    <div class="day-nav"></div>

    <div class="grid">
        <div class="head button" style="grid-column: span 8;">
            <button class="chg-week">←</button>
            <p id="week-label">Week 1</p>
            <button class="chg-week">→</button>
        </div>
        <div class="head time">Time</div>
        <div class="head slot">Monday</div>
        <div class="head slot">Tuesday</div>
        <div class="head slot">Wednesday</div>
        <div class="head slot">Thursday</div>
        <div class="head slot">Friday</div>
        <div class="head slot">Saturday</div>
        <div class="head slot">Sunday</div>
    </div>
</section>

<script>
    import { decodeAsync } from "astro:schema";

    const RAW_URL =
        "https://raw.githubusercontent.com/AI-for-Ocean/workshop2026/refs/heads/main/README.md";
    let DISPLAY_WEEK = 1;

    async function fetchSchedule() {
        const response = await fetch(RAW_URL);
        const text = await response.text();
        return text;
    }

    async function parseSchedule() {
        const text = await fetchSchedule();
        const lines = text.split("\n");
        const dayPattern =
            /##\s*(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday),\s*(July)\s*(\d+).*/;
        const eventPattern = /-\s*(\d+:\d+).(\d+:\d+)\s*.\s*(.*)/;
        const days = [];
        const schedules = [];

        let lidx = 0;
        while (lidx < lines.length) {
            const dayMatch = lines[lidx].match(dayPattern);
            if (dayMatch) {
                const daySchedule = [];
                days.push([dayMatch[1], dayMatch[2], dayMatch[3]]);

                while (true) {
                    lidx++;
                    if (lines[lidx].trim() === "") {
                        continue;
                    }

                    const lineMatch = lines[lidx].match(eventPattern);
                    if (lineMatch) {
                        const [startTime, endTime, title] = [
                            lineMatch[1],
                            lineMatch[2],
                            lineMatch[3],
                        ];
                        let [startHour, startMin] = startTime
                            .split(":")
                            .map((v) => Number(v.trim()));
                        let [endHour, endMin] = endTime
                            .split(":")
                            .map((v) => Number(v.trim()));
                        let startMinutes = startHour * 60 + startMin;
                        let endMinutes = endHour * 60 + endMin;
                        if (startMinutes % 10 === 5) startMinutes += 5;
                        if (endMinutes % 10 === 5) endMinutes += 5;
                        daySchedule.push([startMinutes, endMinutes, title]);
                    } else {
                        schedules.push(daySchedule);
                        break;
                    }
                }
            } else {
                lidx++;
            }
        }

        return { days, schedules };
    }

    async function displaySchedule() {
        const { days, schedules } = await parseSchedule();
        schedules.push([
            [9 * 60, 21 * 60, "Thank you for attending AI4Ocean2026!"],
        ]);
        schedules.push([
            [9 * 60, 21 * 60, "Thank you for attending AI4Ocean2026!"],
        ]);
        console.log(schedules);
        const grid = document.querySelector(".grid")!;
        grid.querySelectorAll(".time-cell, .slot-cell").forEach((el) =>
            el.remove(),
        );
        const startMinutes = 9 * 60;
        const endMinutes = 21 * 60 - 1;
        const slotMinutes = 10;
        const EVENT_COLORS = ["#cccccc", "#ffffff"];

        for (
            let minutes = startMinutes;
            minutes <= endMinutes;
            minutes += slotMinutes
        ) {
            const hours = Math.floor(minutes / 60);
            const mins = minutes % 60;
            const timeStr = `${hours.toString().padStart(2, "0")}:${mins.toString().padStart(2, "0")}`;

            const timeDiv = document.createElement("div");
            timeDiv.className = "time-cell";
            timeDiv.textContent = timeStr;
            grid.appendChild(timeDiv);

            const startDay = DISPLAY_WEEK === 1 ? 0 : 7;
            const endDay = startDay + 7;
            for (let dayIdx = startDay; dayIdx < endDay; dayIdx++) {
                const eventIndexInDay =
                    schedules[dayIdx]?.findIndex(
                        ([startMin]) => Number(startMin) === minutes,
                    ) ?? -1;
                const event =
                    eventIndexInDay >= 0
                        ? schedules[dayIdx]?.[eventIndexInDay]
                        : undefined;
                if (event) {
                    const [startMin, endMin, title] = event as [
                        number,
                        number,
                        string,
                    ];
                    const duration = endMin - startMin;
                    const span = Math.max(
                        1,
                        duration % slotMinutes === 0
                            ? duration / slotMinutes
                            : Math.ceil(duration / slotMinutes),
                    );
                    const slotDiv = document.createElement("div");
                    slotDiv.className = "slot-cell";
                    slotDiv.textContent = title;
                    slotDiv.style.gridRow = `span ${span}`;
                    const color =
                        EVENT_COLORS[
                            ((((dayIdx % 7) + 6) % 7) + eventIndexInDay) %
                                EVENT_COLORS.length
                        ];
                    slotDiv.style.backgroundColor = color;
                    // slotDiv.style.border = `1px solid #000000`;
                    grid.appendChild(slotDiv);
                } else {
                    if (
                        schedules[dayIdx]?.some(
                            ([startMin, endMin]) =>
                                Number(startMin) <= minutes &&
                                minutes < Number(endMin),
                        )
                    ) {
                        continue;
                    }
                    const emptyDiv = document.createElement("div");
                    emptyDiv.className = "slot-cell";
                    grid.appendChild(emptyDiv);
                }
            }
        }
    }

    displaySchedule();

    document.querySelectorAll(".chg-week").forEach((btn) => {
        btn.addEventListener("click", () => {
            DISPLAY_WEEK = DISPLAY_WEEK === 1 ? 2 : 1;
            displaySchedule();
            document.getElementById("week-label")!.textContent =
                `Week ${DISPLAY_WEEK}`;
        });
    });
</script>

