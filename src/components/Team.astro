---
import { Image } from "astro:assets";
import teamData from "../data/bios.json";
import placeholderImg from "../assets/headshots/placeholder.png";
import AnRoy from "../assets/headshots/An-Roy.jpeg";
import ApteDhruv from "../assets/headshots/Apte-Dhruv.jpg";
import BaiYue from "../assets/headshots/Bai-Yue.png";
import BissonKelsey from "../assets/headshots/Bisson-Kelsey.jpg";
import CaiLevi from "../assets/headshots/Cai-Levi.jpg";
import CalindiKrishna from "../assets/headshots/Calindi-Krishna.jpg";
import CastilloBrandon from "../assets/headshots/Castillo-Brandon.jpg";
import CruzEthan from "../assets/headshots/Cruz-Ethan.jpeg";
import DietrichMaya from "../assets/headshots/Dietrich-Maya.jpg";
import EarlyJeffery from "../assets/headshots/Early-Jeffery.jpeg";
import FanZhiwen from "../assets/headshots/Fan-Zhiwen.jpg";
import FentyIan from "../assets/headshots/Fenty-Ian.jpg";
import GeXiao from "../assets/headshots/Ge-Xiao.jpg";
import GlaserYannik from "../assets/headshots/Glaser-Yannik.jpg";
import HarveyLauren from "../assets/headshots/Harvey-Lauren.jpg";
import HoAllison from "../assets/headshots/Ho-Allison.jpg";
import HuaJunwei from "../assets/headshots/Hua-Junwei.jpg";
import HuangMinghai from "../assets/headshots/Huang-Minghai.png";
import JanneyAidan from "../assets/headshots/Janney-Aidan.png";
import JonesSpencer from "../assets/headshots/Jones-Spencer.jpg";
import KimHorim from "../assets/headshots/Kim-Horim.jpg";
import KolsterMartin from "../assets/headshots/Kolster-Martin.jpg";
import LiSuyue from "../assets/headshots/Li-Suyue.png";
import ManucharyanGeorgy from "../assets/headshots/Manucharyan-Georgy.png";
import MartinScott from "../assets/headshots/Martin-Scott.jpg";
import MedvedevAndrei from "../assets/headshots/Medvedev-Andrei.jpg";
import MonkmanTatsu from "../assets/headshots/Monkman-Tatsu.jpg";
import NeremSteve from "../assets/headshots/Nerem-Steve.jpeg";
import ProchaskaJason from "../assets/headshots/Prochaska-Jason.jpg";
import ShahriarTanvir from "../assets/headshots/Shahriar-Tanvir.jpg";
import ShifferNadya from "../assets/headshots/Shiffer-Nadya.jpg";
import SoaresSaulo from "../assets/headshots/Soares-Saulo.jpeg";
import StopaJustin from "../assets/headshots/Stopa-Justin.jpg";
import VenukanthanNayana from "../assets/headshots/Venukanthan-Nayana.jpg";
import WangJinbo from "../assets/headshots/Wang-Jinbo.png";

const headshots = {
  "An-Roy.jpeg": AnRoy,
  "Apte-Dhruv.jpg": ApteDhruv,
  "Bai-Yue.png": BaiYue,
  "Bisson-Kelsey.jpg": BissonKelsey,
  "Cai-Levi.jpg": CaiLevi,
  "Calindi-Krishna.jpg": CalindiKrishna,
  "Castillo-Brandon.jpg": CastilloBrandon,
  "Cruz-Ethan.jpeg": CruzEthan,
  "Dietrich-Maya.jpg": DietrichMaya,
  "Early-Jeffery.jpeg": EarlyJeffery,
  "Fan-Zhiwen.jpg": FanZhiwen,
  "Fenty-Ian.jpg": FentyIan,
  "Ge-Xiao.jpg": GeXiao,
  "Glaser-Yannik.jpg": GlaserYannik,
  "Harvey-Lauren.jpg": HarveyLauren,
  "Ho-Allison.jpg": HoAllison,
  "Hua-Junwei.jpg": HuaJunwei,
  "Huang-Minghai.png": HuangMinghai,
  "Janney-Aidan.png": JanneyAidan,
  "Jones-Spencer.jpg": JonesSpencer,
  "Kim-Horim.jpg": KimHorim,
  "Kolster-Martin.jpg": KolsterMartin,
  "Li-Suyue.png": LiSuyue,
  "Manucharyan-Georgy.png": ManucharyanGeorgy,
  "Martin-Scott.jpg": MartinScott,
  "Medvedev-Andrei.jpg": MedvedevAndrei,
  "Monkman-Tatsu.jpg": MonkmanTatsu,
  "Nerem-Steve.jpeg": NeremSteve,
  "Prochaska-Jason.jpg": ProchaskaJason,
  "Shahriar-Tanvir.jpg": ShahriarTanvir,
  "Shiffer-Nadya.jpg": ShifferNadya,
  "Soares-Saulo.jpeg": SoaresSaulo,
  "Stopa-Justin.jpg": StopaJustin,
  "Venukanthan-Nayana.jpg": VenukanthanNayana,
  "Wang-Jinbo.png": WangJinbo,
};
---

<section id="team" class="team">
  <h2>Meet the team</h2>

  {
    ["organizer", "lecturer", "invited speaker", "participant"].map(
      (role) => (
        <div class="role-section">
          <h3>{role.charAt(0).toUpperCase() + role.slice(1) + "s"}</h3>
          <div class="team-grid" >
            {teamData
              .filter((m) => m.role === role)
              .map((member) => (
                <div class="team-card" onclick={`document.getElementById('popup-${member.email}').showModal()`}>
                  <Image
                    src={headshots[member.photo_filename as keyof typeof headshots] || placeholderImg}
                    alt={member.name}
                    class="team-photo"
                  />
                  <div class="details">
                  <h4>{member.name}</h4>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
  <polyline points="15 3 21 3 21 9" />
  <line x1="10" y1="14" x2="21" y2="3" />
</svg>
                  </div>
                </div>

                <dialog id={`popup-${member.email}`} class="bio-popup">
          <div class="popup-content">
            <button class="close-btn" onclick="this.closest('dialog').close()">✕</button>
            <Image
              src={headshots[member.photo_filename as keyof typeof headshots] || placeholderImg}
              alt={member.name}
              class="popup-photo"
        />
            <h3>{member.name}</h3>
            <p class="popup-bio">{member.bio}</p>
          </div>
        </dialog>
              ))}
          </div>
        </div>
      ),
    )
  }
</section>

<style>
  .team {
    padding: 1rem 5rem;
  }

  .team-section {
    margin-bottom: 2rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 15rem));
    gap: 2rem;
    justify-content: left;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: #000;
    background-color: #d9e4f0;;
    cursor: pointer;
  }

  .team-photo {
    width: 15rem;
    height: 18rem;
    object-fit: cover;
  }


  .details {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .bio-popup {
  border: none;
  border-radius: 8px;
  padding: 0;
  max-width: 500px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
}

.bio-popup::backdrop {
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  padding: 2rem;
  position: relative;
}

.close-btn {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: none;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: #666;
}

.close-btn:hover {
  color: #000;
}

.popup-photo {
  width: 100%;
  height: 300px;
  object-fit: cover;
  border-radius: 4px;
  margin-bottom: 1rem;
}

.popup-bio {
  color: #555;
  line-height: 1.6;
  margin: 0;
}
    a,
    a:visited,
    a:hover,
    a:active,
    a:focus {
        color: #000;
        text-decoration: none;
    }
</style>
